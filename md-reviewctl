#!/usr/bin/env python3
import argparse
import getpass
import os
import secrets
import shutil
import socket
import subprocess
import sys
import time


def resolve_root():
    env_root = os.environ.get('MD_REVIEW_ROOT', '').strip()
    if env_root:
        return os.path.abspath(env_root)

    script_dir = os.path.abspath(os.path.dirname(__file__))
    for candidate in (script_dir, os.getcwd()):
        if os.path.exists(os.path.join(candidate, 'server', 'run.py')):
            return candidate
    raise SystemExit('Set MD_REVIEW_ROOT to the project root')


def current_username():
    return getpass.getuser()


def env_flag(name, default):
    return os.environ.get(name, default)


def root_dir():
    return resolve_root()


def data_dir():
    return os.path.join(root_dir(), 'data')


def pid_file():
    return env_flag('PID_FILE', os.path.join(data_dir(), 'md_review.pid'))


def log_file():
    return env_flag('LOG_FILE', os.path.join(data_dir(), 'server.log'))


def port():
    return env_flag('PORT', '18080')


def host():
    return env_flag('HOST', '0.0.0.0')


def app_base_path():
    return env_flag('APP_BASE_PATH', '')


def venv_dir():
    return env_flag('VENV_DIR', os.path.join(root_dir(), '.venv'))


def secret_file():
    return env_flag('SECRET_FILE', os.path.join(data_dir(), 'secret_key'))


def database_path():
    return env_flag('DATABASE_PATH', os.path.join(data_dir(), 'md_review.db'))


def session_file_dir():
    return env_flag('SESSION_FILE_DIR', os.path.join(data_dir(), 'flask_session'))


def workers():
    return env_flag('WORKERS', '2')


def threads():
    return env_flag('THREADS', '4')


def ensure_secret_file():
    secret_path = secret_file()
    if not os.path.exists(secret_path):
        os.makedirs(os.path.dirname(secret_path), exist_ok=True)
        with open(secret_path, 'w', encoding='utf-8') as handle:
            handle.write(secrets.token_urlsafe(48))
        os.chmod(secret_path, 0o600)
    return secret_path


def read_secret():
    secret_path = ensure_secret_file()
    with open(secret_path, encoding='utf-8') as handle:
        return handle.read().strip()


def url_path():
    base_path = app_base_path().strip()
    if not base_path:
        return '/'
    return f"{base_path.rstrip('/')}/"


def server_ip():
    try:
        output = subprocess.check_output(['hostname', '-I'], text=True).strip()
        if output:
            return output.split()[0]
    except Exception:
        pass
    return '127.0.0.1'


def tunnel_host():
    try:
        return subprocess.check_output(['hostname', '-f'], text=True).strip()
    except Exception:
        return socket.gethostname()


def process_is_running(pid):
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False


def read_pid():
    pid_path = pid_file()
    if not os.path.exists(pid_path):
        return None
    with open(pid_path, encoding='utf-8') as handle:
        raw = handle.read().strip()
    if not raw:
        return None
    try:
        return int(raw)
    except ValueError:
        return None


def port_is_in_use():
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        sock.bind((host(), int(port())))
    except OSError:
        return True
    finally:
        sock.close()
    return False


def ensure_venv():
    if not os.path.isdir(venv_dir()):
        subprocess.run([sys.executable, '-m', 'venv', venv_dir()], check=True)
    subprocess.run([os.path.join(venv_dir(), 'bin', 'pip'), 'install', '--upgrade', 'pip'], check=True, stdout=subprocess.DEVNULL)
    subprocess.run([os.path.join(venv_dir(), 'bin', 'pip'), 'install', '-r', os.path.join(root_dir(), 'server', 'requirements.txt')], check=True)


def runtime_env():
    secret = os.environ.get('SECRET_KEY', '').strip() or read_secret()
    env = os.environ.copy()
    env.update({
        'SECRET_KEY': secret,
        'DATABASE_PATH': database_path(),
        'SESSION_FILE_DIR': session_file_dir(),
        'APP_BASE_PATH': app_base_path(),
    })
    return env


def print_running_info(pid):
    print(f'md_review is running with PID {pid}')
    print(f'Web app: http://{server_ip()}:{port()}{url_path()}')
    print(f'SSH tunnel: ssh -L {port()}:127.0.0.1:{port()} {current_username()}@{tunnel_host()}')
    print(f'Browser via tunnel: http://127.0.0.1:{port()}{url_path()}')
    print(f'Logs: {log_file()}')


def cmd_start(args):
    os.makedirs(data_dir(), exist_ok=True)
    os.makedirs(session_file_dir(), exist_ok=True)
    ensure_venv()

    pid = read_pid()
    if pid and process_is_running(pid):
        print_running_info(pid)
        return
    if pid is not None:
        try:
            os.remove(pid_file())
        except FileNotFoundError:
            pass

    if port_is_in_use():
        raise SystemExit(f'Port {port()} is already in use. Pick another one with PORT=...')

    env = runtime_env()
    gunicorn = os.path.join(venv_dir(), 'bin', 'gunicorn')
    subprocess.run([
        gunicorn,
        '--chdir', os.path.join(root_dir(), 'server'),
        '--bind', f'{host()}:{port()}',
        '--workers', workers(),
        '--threads', threads(),
        '--pid', pid_file(),
        '--access-logfile', log_file(),
        '--error-logfile', log_file(),
        '--capture-output',
        '--daemon',
        'run:create_app()',
    ], check=True, cwd=os.path.join(root_dir(), 'server'), env=env)

    time.sleep(2)
    pid = read_pid()
    if not pid or not process_is_running(pid):
        raise SystemExit(f'Failed to start md_review. Check {log_file()}')
    print_running_info(pid)


def cmd_stop(args):
    pid = read_pid()
    if not pid:
        print('md_review is not running')
        return
    try:
        os.kill(pid, 15)
        print(f'Stopped md_review (PID {pid})')
    except ProcessLookupError:
        print('Stale PID file removed')
    try:
        os.remove(pid_file())
    except FileNotFoundError:
        pass


def cmd_status(args):
    pid = read_pid()
    if not pid:
        raise SystemExit('md_review is not running')
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        raise SystemExit('md_review pid file exists but process is not running')
    print('md_review is running')
    print(f'PID: {pid}')
    print(f'Port: {port()}')
    print(f'Log: {log_file()}')
    if shutil.which('ss'):
        subprocess.call(['ss', '-ltnp'])


def build_parser():
    parser = argparse.ArgumentParser(prog='md-reviewctl')
    subparsers = parser.add_subparsers(dest='command', required=True)

    start_parser = subparsers.add_parser('start')
    start_parser.set_defaults(func=cmd_start)

    stop_parser = subparsers.add_parser('stop')
    stop_parser.set_defaults(func=cmd_stop)

    status_parser = subparsers.add_parser('status')
    status_parser.set_defaults(func=cmd_status)
    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
